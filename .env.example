# Public production URL used for SEO canonical URLs and deployment.
NEXT_PUBLIC_SITE_URL=https://eviternite.shop

# Supabase project settings.
# Get these from Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key.
# Never expose this in browser code. Add it only in .env.local and Vercel environment variables.
SUPABASE_SERVICE_ROLE_KEY=

# Optional email notifications.
# Get RESEND_API_KEY from Resend. If empty, package orders still save to Supabase but email notifications are skipped.
RESEND_API_KEY=
CONTACT_EMAIL=poqimedia@gmail.com

# Simple admin login for /admin.
# Replace with strong production values before deployment.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SECRET=

# Public WhatsApp number used by buttons.
# Use international format without plus signs or spaces, for example: 355XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Optional analytics placeholders.
# Add IDs later when Google Analytics/Search Console/Meta Pixel/Microsoft Clarity are connected.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
